---
const education = [
  {
    degree: "Master of Science in Information Systems",
    school: "Northeastern University",
    location: "Toronto, Canada",
    period: "Sept 2022 — Apr 2024",
  },
  {
    degree: "Bachelor of Engineering in Industrial Engineering",
    school: "College Of Engineering (CEG), Anna University",
    location: "India",
    period: "Aug 2015 — Apr 2019",
  },
];
---

<section id="education">
  <div class="container">
    <p class="section-label">Education</p>
    <h2 class="section-title">Qualifications</h2>

    <div class="education-list">
      {
        education.map((edu, i) => (
          <div class="education-item">
            <div class="edu-marker">
              <div class="marker-dot" />
              {i < education.length - 1 && <div class="marker-line" />}
            </div>
            <div class="edu-content">
              <div class="edu-header">
                <div>
                  <h3 class="edu-degree">{edu.degree}</h3>
                  <p class="edu-school">
                    {edu.school} ·{" "}
                    <span class="edu-location">{edu.location}</span>
                  </p>
                </div>
                <span class="edu-period">{edu.period}</span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  #education {
    background: var(--white);
    border-top: 1px solid var(--sand);
    border-bottom: 1px solid var(--sand);
  }

  .education-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .education-item {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 1.5rem;
  }

  .edu-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.35rem;
  }

  .marker-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--terracotta);
    border: 3px solid var(--white);
    box-shadow: 0 0 0 2px var(--terracotta);
    flex-shrink: 0;
  }

  .marker-line {
    width: 2px;
    flex: 1;
    background: var(--sand);
    margin: 0.5rem 0;
    min-height: 2rem;
  }

  .edu-content {
    background: var(--cream);
    border: 1px solid var(--sand);
    border-radius: 1rem;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
    transition: box-shadow 0.2s;
  }

  .edu-content:hover {
    box-shadow: 0 6px 24px rgba(44, 36, 34, 0.07);
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .edu-degree {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 0.2rem;
  }

  .edu-school {
    font-size: 0.875rem;
    color: var(--muted);
    font-weight: 400;
  }

  .edu-location {
    color: var(--charcoal-soft);
  }

  .edu-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .education-item {
      grid-template-columns: 2rem 1fr;
      gap: 1rem;
    }

    .edu-degree {
      font-size: 1.05rem;
    }

    .edu-header {
      flex-direction: column;
      gap: 0.5rem;
    }

    .edu-period {
      font-size: 0.7rem;
    }
  }
</style>
