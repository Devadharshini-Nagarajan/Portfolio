---

---

<section id="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-text fade-up">
        <span class="greeting">👋 Hello, I'm</span>
        <h1><em>Deva</em>dharshini</h1>
        <p class="tagline">
          Software developer with 5 years of experience building scalable,
          production-ready web applications — with care, curiosity, and clean
          code.
        </p>
        <div class="hero-actions">
          <a href="#projects" class="btn-primary">See My Work</a>
          <a href="#contact" class="btn-ghost">Get In Touch</a>
        </div>
      </div>

      <div class="hero-card fade-up" style="animation-delay: 0.2s">
        <div class="card-inner">
          <div class="avatar-ring">
            <div class="avatar-placeholder">DN</div>
          </div>
          <div class="status-badge">
            <span class="dot"></span> Available for work
          </div>
          <div class="hero-meta">
            <div class="meta-item">
              <span class="meta-label">Based in</span>
              <span class="meta-value">Toronto, Canada</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Experience</span>
              <span class="meta-value">5+ Years</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Specialty</span>
              <span class="meta-value"
                >Fullstack Typescript & Node</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="scroll-hint">
      <span>Scroll to explore</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 4rem;
    align-items: center;
  }

  .greeting {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--terracotta);
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 1rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--charcoal);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  h1 em {
    font-style: italic;
    color: var(--terracotta);
  }

  .tagline {
    font-size: 1.15rem;
    color: var(--charcoal-soft);
    max-width: 480px;
    line-height: 1.75;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--terracotta);
    color: var(--white);
    padding: 0.85rem 2rem;
    border-radius: 3rem;
    font-weight: 500;
    font-size: 0.9rem;
    transition:
      background 0.2s,
      transform 0.2s;
  }

  .btn-primary:hover {
    background: var(--terracotta-light);
    opacity: 1;
    transform: translateY(-1px);
  }

  .btn-ghost {
    border: 1.5px solid var(--charcoal);
    color: var(--charcoal);
    padding: 0.85rem 2rem;
    border-radius: 3rem;
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--terracotta);
    color: var(--terracotta);
    opacity: 1;
  }

  /* Card */
  .hero-card {
    animation-delay: 0.2s;
  }

  .card-inner {
    background: var(--white);
    border: 1px solid var(--sand);
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 0 8px 40px rgba(44, 36, 34, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .avatar-ring {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 3px solid var(--terracotta);
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--sand);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--terracotta);
  }

  /* Replace .avatar-placeholder with an <img> once you have a photo:
     <img src="/avatar.jpg" alt="Your Name" class="avatar-img" /> */

  .status-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #eff7ee;
    color: #3a7a35;
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.35rem 1rem;
    border-radius: 2rem;
    font-family: var(--font-mono);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4caf50;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  .hero-meta {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-top: 1px solid var(--sand);
    padding-top: 1.25rem;
  }

  .meta-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }

  .meta-label {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .meta-value {
    color: var(--charcoal);
    font-weight: 500;
  }

  /* Scroll hint */
  .scroll-hint {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .scroll-line {
    height: 1px;
    width: 4rem;
    background: var(--muted);
  }

  @media (max-width: 800px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-card {
      order: -1;
      max-width: 320px;
    }
    h1 {
      font-size: 3rem;
    }
  }
</style>
